# Firebase (obrigatório para produção — crie um projeto em https://console.firebase.google.com)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL pública do app (links em e-mails de recuperação de senha)
VITE_APP_URL=http://localhost:5173

# Permite /setup-admin fora do modo dev (use false em produção)
VITE_ALLOW_SETUP=false

# WhatsApp do suporte (DDI + DDD + número, só dígitos)
VITE_SUPPORT_WHATSAPP=5511999999999
VITE_SUPPORT_WHATSAPP_LABEL=Suporte RH
VITE_SUPPORT_WHATSAPP_DEFAULT_MESSAGE=Olá! Preciso de ajuda com o Sistema de Gestão RH.

# Emulador de Cloud Functions (opcional, dev)
# VITE_USE_FUNCTIONS_EMULATOR=true

# EmailJS — notificações por e-mail no frontend (opcional)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
