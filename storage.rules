rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /caderno_virtual/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /boletins_medicao/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /documentos_financeiros/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
